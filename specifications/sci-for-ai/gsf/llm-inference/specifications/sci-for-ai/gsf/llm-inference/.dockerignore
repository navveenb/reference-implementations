# Keep the Docker context lean — every megabyte in context is bandwidth
# burned on every build, and CI builds are frequent.
.git
.github
.venv
__pycache__/
**/__pycache__/
*.pyc
*.pyo
.pytest_cache
.mypy_cache
.coverage
htmlcov/
dist/
build/
*.egg-info/
.env
.env.*
.DS_Store
*.log

# Tests and dev scaffolding are not needed in the runtime image.
tests/
docs/
examples/
requirements-dev.txt
